{
  "expo": {
    "name": "Freshman Registration",
    "slug": "bvritn-document-verification",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EFF6FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bvritn.freshmanregistration",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Freshman Registration needs camera access to upload document photos.",
        "NSPhotoLibraryUsageDescription": "Freshman Registration needs photo library access to select documents.",
        "NSPhotoLibraryAddUsageDescription": "Freshman Registration needs permission to save photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#EFF6FF"
      },
      "package": "com.bvritn.freshmanregistration",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Freshman Registration to access your photos to upload documents.",
          "cameraPermission": "Allow Freshman Registration to use your camera to capture document photos.",
          "microphonePermission": false
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id-here"
      }
    }
  }
}
